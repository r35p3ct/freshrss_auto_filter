            </p>
            <div class="auto-filter-channels-tree">
                <?php
                $channelsFilter = $this->getSystemConfigurationValue('channels_filter');
                if (!is_array($channelsFilter)) {
                    $channelsFilter = [];
                }
                
                $catDAO = FreshRSS_Factory::createCategoryDao();
                $categories = $catDAO->listSortedCategories();
                
                foreach ($categories as $category) {
                    $catId = $category->id();
                    $catName = htmlspecialchars($category->name(), ENT_QUOTES);
                    $feeds = $category->feeds();
                    
                    if (empty($feeds)) {
                        continue;
                    }
                    
                    echo '<div class="channel-category">';
                    echo '<label class="channel-category-label">';
                    echo '<input type="checkbox" class="channel-category-toggle" data-category="' . $catId . '" /> ';
                    echo '<strong>' . $catName . '</strong>';
                    echo '</label>';
                    
                    echo '<div class="channel-feeds" id="category-feeds-' . $catId . '">';
                    foreach ($feeds as $feed) {
                        $feedId = $feed->id();
                        $feedName = htmlspecialchars($feed->name(), ENT_QUOTES);
                        $isSelected = in_array((string)$feedId, $channelsFilter, true) ? 'checked' : '';
                        
                        echo '<label class="channel-feed-item">';
                        echo '<input type="checkbox" name="auto_filter_channels_filter[]" value="' . $feedId . '" ' . $isSelected . ' />';
                        echo htmlspecialchars($feedName, ENT_QUOTES);
                        echo '</label>';
                    }
                    echo '</div>';
                    
                    echo '</div>';
                }
                ?>
            </div>
            <p class="help">
                <label>
                    <input type="checkbox" id="auto_filter_select_all_channels" />
                    <?php echo _t('ext.field.select_all_channels'); ?>
                </label>
            </p>
