    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Переключение всех каналов категории
            document.querySelectorAll('.channel-category-toggle').forEach(function(toggle) {
                toggle.addEventListener('change', function() {
                    var categoryId = this.dataset.category;
                    var feedsContainer = document.getElementById('category-feeds-' + categoryId);
                    
                    if (!feedsContainer) {
                        console.error('Контейнер для категорий не найден: category-feeds-' + categoryId);
                        return;
                    }

                    var checkboxes = feedsContainer.querySelectorAll('input[type="checkbox"]');
                    checkboxes.forEach(function(cb) {
                        cb.checked = toggle.checked;
                    });
                });
            });

            // Выделение категории жирным при выборе
            document.querySelectorAll('.channel-category-label').forEach(function(label) {
                label.addEventListener('click', function(e) {
                    // Проверяем, что клик был не по чекбоксу
                    if (e.target.tagName !== 'INPUT') {
                        var toggle = this.querySelector('.channel-category-toggle');
                        if (toggle) {
                            toggle.checked = !toggle.checked;
                            toggle.dispatchEvent(new Event('change'));
                        }
                    }
                });
            });

            // Выбрать все каналы
            document.getElementById('auto_filter_select_all_channels').addEventListener('change', function() {
                var allChecked = this.checked;
                document.querySelectorAll('.auto-filter-channels-tree input[type="checkbox"]').forEach(function(cb) {
                    cb.checked = allChecked;
                });
            });
        });
    </script>

    <div class="form-group form-actions">
