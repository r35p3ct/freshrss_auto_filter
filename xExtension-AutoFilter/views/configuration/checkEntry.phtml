<?php
/** @var FreshExtension_AutoFilter_configuration_Controller $this */
?>

<div class="alert <?= $this->success ? 'alert-success' : 'alert-error' ?>">
    <?= $this->message ?>
</div>

<?php if ($this->analysis): ?>
<div class="post">
    <h3><?= _t('gen.autofilter.title') ?></h3>
    <dl>
        <dt><?= _t('gen.label.advertisement') ?>:</dt>
        <dd><?= $this->analysis['is_advertisement'] ? _t('gen.action.yes') : _t('gen.action.no') ?></dd>

        <dt><?= _t('ext.field.confidence_threshold_low') ?>:</dt>
        <dd><?= round($this->analysis['confidence'] * 100, 2) ?>%</dd>

        <dt><?= _t('gen.label.possible_advertisement') ?>:</dt>
        <dd><?= $this->analysis['label'] ?? _t('gen.autofilter.action_none') ?></dd>

        <dt>Обоснование:</dt>
        <dd><?= $this->analysis['reason'] ?? _t('gen.autofilter.action_none') ?></dd>
    </dl>
</div>
<?php endif; ?>
